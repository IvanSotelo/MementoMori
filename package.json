{
  "name": "memento-mori",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint:js": "eslint .",
    "lint:ts": "vue-tsc --noEmit",
    "lint:prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint:style": "stylelint \"**/*.{scss,css}\"",
    "lint": "pnpm run lint:js && pnpm run lint:ts && pnpm run lint:prettier && pnpm run lint:style",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "lint-staged": {
    "*.{cjs,css,js,jsx,json,md,mjs,scss,ts,tsx,vue}": "prettier --write"
  },
  "dependencies": {
    "@nuxt/eslint": "1.16.0",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/i18n": "^10.4.1",
    "@nuxtjs/seo": "^5.3.3",
    "@pinia/nuxt": "^1.0.1",
    "dom-classes": "^1.0.0",
    "eslint": "^10.7.0",
    "howler": "^2.2.4",
    "isotope-layout": "^3.0.6",
    "locomotive-scroll": "^4.1.4",
    "nuxt": "^4.4.8",
    "nuxt-gtag": "^4.1.0",
    "pinia": "^4.0.2",
    "swiper": "^12.2.0",
    "unhead": "^3.2.1",
    "vue": "latest",
    "vue-router": "latest"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@nuxt/schema": "4",
        "unhead": "2"
      }
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@hypernym/nuxt-gsap": "^2.4.3",
    "@types/howler": "^2.2.13",
    "@types/locomotive-scroll": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "pug": "^3.0.4",
    "pug-plain-loader": "^1.1.0",
    "sass": "^1.101.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.7"
  }
}
